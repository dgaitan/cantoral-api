# Copy this file to .env.kamal (gitignored) and fill in real values.
# Never commit .env.kamal — it holds production secrets.

# Generate with:
#   uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# A hard-to-guess path for the admin UI, e.g. "django-admin-a1b2c3/"
DJANGO_ADMIN_URL=

# From DigitalOcean Managed Database (Postgres) connection details page.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=

# Redis runs as a Kamal accessory on the same droplet — leave this as-is
# unless you move Redis elsewhere.
REDIS_URL=redis://redis:6379/0

# DigitalOcean API token (Container Registry read/write scope).
# API -> Tokens -> Generate New Token in the DO dashboard.
DO_REGISTRY_TOKEN=
