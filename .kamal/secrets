# Kamal loads this file via the `dotenv` gem — plain KEY=VALUE parsing only.
# It does NOT execute shell statements like `set -a` / `source`, so those
# are silently skipped and every value below would resolve empty. Instead,
# pull each value out of the untracked .env.kamal at the repo root with a
# command substitution per line (the pattern Kamal's own docs use for
# reading secrets from another file).
#
# Populate .env.kamal with real values before running any `kamal` command:
#
#   DJANGO_SECRET_KEY=...
#   DJANGO_ADMIN_URL=...
#   DATABASE_URL=...
#   REDIS_URL=redis://redis:6379/0
#   DO_REGISTRY_TOKEN=...

ENV_KAMAL_FILE=$(git rev-parse --show-toplevel)/.env.kamal

DJANGO_SECRET_KEY=$(grep -m1 '^DJANGO_SECRET_KEY=' "$ENV_KAMAL_FILE" | cut -d= -f2- | tr -d '"')
DJANGO_ADMIN_URL=$(grep -m1 '^DJANGO_ADMIN_URL=' "$ENV_KAMAL_FILE" | cut -d= -f2- | tr -d '"')
DATABASE_URL=$(grep -m1 '^DATABASE_URL=' "$ENV_KAMAL_FILE" | cut -d= -f2- | tr -d '"')
REDIS_URL=$(grep -m1 '^REDIS_URL=' "$ENV_KAMAL_FILE" | cut -d= -f2- | tr -d '"')
KAMAL_REGISTRY_PASSWORD=$(grep -m1 '^DO_REGISTRY_TOKEN=' "$ENV_KAMAL_FILE" | cut -d= -f2- | tr -d '"')
DJANGO_ALLOWED_HOSTS=$(grep -m1 '^DJANGO_ALLOWED_HOSTS=' "$ENV_KAMAL_FILE" | cut -d= -f2- | tr -d '"')